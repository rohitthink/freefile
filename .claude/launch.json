{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "freefile-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    },
    {
      "name": "freefile-backend",
      "runtimeExecutable": "venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--port", "8000"],
      "port": 8000
    }
  ]
}
